# ============================================================
# Webhook (env vars do projeto Vercel, não deste arquivo local)
# ============================================================
# Gere com: openssl rand -hex 16. Vai também na URL registrada na uazapi (?secret=...)
UAZAPI_WEBHOOK_SECRET=
# Número do dono com DDI, só dígitos (fallback pra detectar menção em grupo)
OWNER_JID=5511999999999
# Supabase > Project Settings > Data API > Project URL
SUPABASE_URL=
# Supabase > Project Settings > API Keys > service_role (Reveal). NUNCA a anon.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Agente de triagem (env do processo que roda agente/secretario.mjs)
# Precisa de: SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY (acima) + estas:
# ============================================================
# @BotFather > /newbot
TELEGRAM_BOT_TOKEN=
# id do supergrupo "Hermes Secretário" (negativo, começa com -100)
TELEGRAM_CHAT_ID=
# ids dos tópicos: rode `node agente/setup-topics.mjs` que ele imprime os três
TELEGRAM_TOPIC_RADAR=
TELEGRAM_TOPIC_PESSOAL=
TELEGRAM_TOPIC_EMPRESA=
# Janela de assentamento: conversa com mensagem mais nova que isso (minutos)
# espera a próxima varredura (a pessoa pode ainda estar digitando)
SETTLE_MINUTES=10

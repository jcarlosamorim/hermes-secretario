# ============================================================
# Webhook (env vars do projeto Vercel, configuradas no import)
# ============================================================
# Gerado pelo Hermes na fase 2 (openssl rand -hex 16). Vai também na URL
# registrada na uazapi (?secret=...)
UAZAPI_WEBHOOK_SECRET=
# Número do dono com DDI, só dígitos (detecta menção/reply em grupo)
OWNER_JID=5511999998888
# Supabase > Project Settings > Data API > Project URL
SUPABASE_URL=
# Supabase > Project Settings > API Keys > service_role (Reveal). NUNCA a anon.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Hermes (ambiente do processo que roda agente/secretario.mjs)
# Usa APENAS estas duas (as mesmas SUPABASE_* acima):
#   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
# Opcional:
# ============================================================
# Janela de assentamento em minutos: conversa com mensagem mais nova que
# isso espera a próxima varredura (a pessoa pode ainda estar digitando)
SETTLE_MINUTES=10
